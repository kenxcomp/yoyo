{
  "description": "Plan review workflow hooks: SessionStart injection, EnterPlanMode cleaner",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-skill.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f ./.plan-review/review-status.md ]; then > ./.plan-review/review-status.md; fi",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
